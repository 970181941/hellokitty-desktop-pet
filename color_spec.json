      "bow_gradient_start": "#FF006E",
      "bow_gradient_end": "#FB5607",
      "body": "#FFFFFF",
      "glow_inner": "#8338EC",
      "glow_outer": "#3A86FF",
      "accent": "#06D6A0",
      "nose": "#FFB300",
      "outline": "#222222",
      "glow_opacity": { "inner": 0.5, "outer": 0.2 }
    },
    "night_mode": {
      "name": "暗夜星梦",
      "bow": "#7B68EE",
      "body": "#E8E0F0",
      "glow_inner": "#1A1A2E",
      "glow_outer": "#7B68EE",
