{
  "name": "HelloKitty Desktop Pet - Color System",
  "version": "1.0.0",
  "skins": {
    "classic_pink": {
      "name": "经典原版",
      "bow": "#FF6B9D",
      "body": "#FFFFFF",
      "glow_inner": "#FFD4E5",
      "glow_outer": "#FF6B9D",
      "nose": "#FFB300",
      "outline": "#333333",
      "glow_opacity": { "inner": 0.6, "outer": 0.15 }
    },
    "macaron_cream": {
      "name": "奶油马卡龙",
      "bow": "#B5D8CC",
      "body": "#FFF9F0",
      "glow_inner": "#F2D7D9",
      "glow_outer": "#B5D8CC",
      "nose": "#E8D5B7",
      "outline": "#6B6B6B",
      "glow_opacity": { "inner": 0.6, "outer": 0.15 }
    },
    "candy_neon": {
